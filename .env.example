# Memory Gateway — Environment Configuration
# Copy this to .env and fill in your values

# --- LLM Provider ---
# Supports: openai, azure, anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_openai_api_key_here
LLM_ENDPOINT=                         # Leave blank for standard OpenAI
LLM_API_VERSION=                      # Required for Azure (e.g. 2024-08-01-preview)

# Azure OpenAI example:
# LLM_PROVIDER=openai
# LLM_MODEL=azure/gpt-4o-mini
# LLM_API_KEY=your_azure_key
# LLM_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o-mini
# LLM_API_VERSION=2024-08-01-preview

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=your_openai_api_key_here
EMBEDDING_API_VERSION=
EMBEDDING_ENDPOINT=
EMBEDDING_DIMENSIONS=3072

# --- Storage ---
# Vector store: lancedb (default, local file) or pgvector (production)
# COGNEE_VECTOR_DB=pgvector
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Graph store: kuzu (default, local file) or falkordb (high concurrency)
# GRAPH_DATABASE_PROVIDER=falkordb
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379

# --- Access Control ---
# Set to false for single-user deployments (required for pgvector)
ENABLE_BACKEND_ACCESS_CONTROL=false

# --- Caching (enables SHARED_KUZU_LOCK for concurrent writes) ---
CACHING=true
CACHE_BACKEND=fs
SHARED_KUZU_LOCK=true

# --- MCP Server ---
MCP_TRANSPORT=http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8002

# --- Telemetry ---
TELEMETRY_DISABLED=true
